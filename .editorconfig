# EditorConfig helps maintain consistent coding styles across different editors
# Visit https://editorconfig.org for more information

# Top-most EditorConfig file
root = true

# Default settings for all files
[*]
charset = utf-8
end_of_line = lf
insert_final_newline = true
trim_trailing_whitespace = true
indent_style = space
indent_size = 2

# JavaScript and JSX files
[*.{js,jsx,mjs,cjs}]
indent_style = space
indent_size = 2
max_line_length = 100

# TypeScript files
[*.{ts,tsx}]
indent_style = space
indent_size = 2
max_line_length = 100

# JSON files
[*.json]
indent_style = space
indent_size = 2

# YAML files
[*.{yml,yaml}]
indent_style = space
indent_size = 2

# Markdown files
[*.md]
trim_trailing_whitespace = false
max_line_length = off

# Package.json
[package.json]
indent_style = space
indent_size = 2

# Configuration files
[*.config.{js,ts,mjs,cjs}]
indent_style = space
indent_size = 2
