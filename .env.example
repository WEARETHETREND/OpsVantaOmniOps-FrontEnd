# ==============================================================================
# ENVIRONMENT CONFIGURATION TEMPLATE
# ==============================================================================
# Copy this file to .env and fill in your actual values
# NEVER commit .env to version control
# ==============================================================================

# ------------------------------------------------------------------------------
# API Configuration
# ------------------------------------------------------------------------------
# Backend API URL (optional - for custom backend integration)
# Development: http://localhost:8000
# Production: https://api.opsvanta.com
VITE_API_URL=http://localhost:8000

# ------------------------------------------------------------------------------
# Supabase Configuration (REQUIRED)
# ------------------------------------------------------------------------------
# Get these values from: https://app.supabase.com/project/_/settings/api
#
# 1. Go to your Supabase project dashboard
# 2. Navigate to Settings > API
# 3. Copy the Project URL and anon/public key
#
# Your Supabase project URL (format: https://xxxxx.supabase.co)
VITE_SUPABASE_URL=https://your-project-id.supabase.co

# Your Supabase anonymous/public key (safe to use in client-side code)
# This key respects your Row Level Security (RLS) policies
VITE_SUPABASE_ANON_KEY=your-supabase-anon-key-here

# ------------------------------------------------------------------------------
# Optional: Analytics & Monitoring
# ------------------------------------------------------------------------------
# Vercel Analytics (automatically enabled on Vercel deployments)
# No configuration needed - works out of the box

# ------------------------------------------------------------------------------
# Optional: Additional Environment Variables
# ------------------------------------------------------------------------------
# Add any custom environment variables your application needs below
# All variables must be prefixed with VITE_ to be accessible in the frontend

# Example: Feature flags
# VITE_FEATURE_AI_BUILDER=true
# VITE_FEATURE_CUSTOM_DOMAINS=true

# Example: External service keys (if needed)
# VITE_STRIPE_PUBLIC_KEY=pk_test_xxxxx
# VITE_GOOGLE_ANALYTICS_ID=G-XXXXXXXXXX

# ==============================================================================
# SECURITY NOTES
# ==============================================================================
# - NEVER commit .env files to version control
# - Rotate keys immediately if accidentally exposed
# - Use different credentials for development and production
# - Keep your Supabase service_role key secure (server-side only)
# - Review Supabase RLS policies regularly
# ==============================================================================
