# ============================================
# Supabase Configuration (REQUIRED)
# ============================================
# Get these values from your Supabase project dashboard
# URL: https://app.supabase.com/project/_/settings/api
#
# Your Supabase project URL (format: https://xxxxx.supabase.co)
VITE_SUPABASE_URL=https://your-project-id.supabase.co

# Your Supabase anonymous/public key (safe to expose in frontend)
# This is a JWT token starting with "eyJ..."
VITE_SUPABASE_ANON_KEY=your_supabase_anon_key_here

# ============================================
# Optional Configuration
# ============================================
# API URL for backend services (if applicable)
# VITE_API_URL=http://localhost:8000
